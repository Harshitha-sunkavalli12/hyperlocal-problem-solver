# Community Hero — frontend environment.
# Copy to `.env`. All optional: features gracefully fall back without keys.

# --- Google Maps JS API (pin-drop + dashboard heatmap) ---
VITE_GOOGLE_MAPS_API_KEY=

# --- Firebase web config (Google sign-in) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
