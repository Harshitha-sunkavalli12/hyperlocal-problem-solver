# Community Hero — backend environment.
# Copy to `.env`. Every value is OPTIONAL: the app runs fully in mock-fallback
# mode without any keys, and upgrades to live Google/AI services when set.

# --- Database (SQLite by default; use Postgres in production) ---
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/community_hero

# --- Google Gemini Vision (image analysis) ---
GEMINI_API_KEY=

# --- Anthropic Claude (agent reasoning narration) ---
ANTHROPIC_API_KEY=

# --- Google Maps server-side (geocoding, optional) ---
GOOGLE_MAPS_API_KEY=

# --- Vertex AI predictive model (Insights Agent) ---
# GCP_PROJECT=
# GCP_REGION=asia-south1
# VERTEX_ENDPOINT_ID=
